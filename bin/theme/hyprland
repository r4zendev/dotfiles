#!/usr/bin/env bash
set -uo pipefail

command -v hyprctl >/dev/null 2>&1 || exit 0
if [ -z "${HYPRLAND_INSTANCE_SIGNATURE:-}" ]; then
    HYPRLAND_INSTANCE_SIGNATURE=$(ls -t "${XDG_RUNTIME_DIR:-/run/user/$(id -u)}/hypr" 2>/dev/null | head -1)
    [ -n "$HYPRLAND_INSTANCE_SIGNATURE" ] || exit 0
    export HYPRLAND_INSTANCE_SIGNATURE
fi

j="$HOME/.cache/matugen/colors.json"
[ -f "$j" ] || exit 0

read -r active inactive < <(jq -r '[.special.cursor, .colors.color8] | map(ltrimstr("#")) | join(" ")' "$j" 2>/dev/null)
[ -n "${active:-}" ] && [ -n "${inactive:-}" ] || exit 0

hyprctl eval "hl.config({ general = { col = { active_border = 'rgb($active)', inactive_border = 'rgb($inactive)' } } }) hl.window_rule({ name = 'refresh-poke', match = { class = '^never-match$' }, enabled = false })" >/dev/null 2>&1 || true

exit 0
