#!/usr/bin/env python3
import json
import os
import re
import shutil
import subprocess
import sys
import tempfile
import zipfile

HOME = os.path.expanduser("~")
CACHE = os.environ.get("XDG_CACHE_HOME", f"{HOME}/.cache")
CONFIG = os.environ.get("XDG_CONFIG_HOME", f"{HOME}/.config")
TPL = f"{CONFIG}/matugen/templates/telegram-colors.tpl"
OUT = f"{CONFIG}/telegram-desktop/themes/matugen.tdesktop-theme"


def adjust(hex_color, amount):
    h = hex_color.lstrip("#")
    ch = [max(0, min(255, int(h[i : i + 2], 16) + amount)) for i in (0, 2, 4)]
    return "#" + "".join(f"{c:02x}" for c in ch)


def main():
    try:
        with open(f"{CACHE}/matugen/colors.json") as f:
            data = json.load(f)
        with open(TPL) as f:
            tpl = f.read()
    except OSError:
        return 0

    s = data["special"]
    c = data["colors"]
    bg, fg = s["background"], s["foreground"]
    p = {
        "accent": s.get("cursor", c["color4"]),
        "surface0": adjust(bg, 15),
        "surface1": adjust(bg, 25),
        "surface2": adjust(bg, 40),
        "mantle": adjust(bg, -5),
        "crust": adjust(bg, -10),
        "overlay0": adjust(fg, -80),
        "overlay1": adjust(fg, -65),
        "overlay2": adjust(fg, -50),
        "subtext0": adjust(fg, -30),
        "subtext1": adjust(fg, -15),
    }
    scopes = {"s": s, "p": p, "c": c}

    def resolve(m):
        expr = m.group(1)
        fn = re.fullmatch(r"adjustLightness\(([spc])\.(\w+), ?(-?\d+)\)", expr)
        if fn:
            return adjust(scopes[fn.group(1)][fn.group(2)], int(fn.group(3)))
        scope, key = expr.split(".", 1)
        return scopes[scope][key]

    colors = re.sub(r"\$\{([^}]+)\}", resolve, tpl)

    os.makedirs(os.path.dirname(OUT), exist_ok=True)

    wp = ""
    try:
        wp = subprocess.run(["dms", "ipc", "call", "wallpaper", "get"], capture_output=True, text=True, timeout=5).stdout.strip()
    except (OSError, subprocess.TimeoutExpired):
        pass

    if wp and os.path.isfile(wp):
        with tempfile.TemporaryDirectory() as work:
            bg_path = f"{work}/background.jpg"
            subprocess.run(["magick", wp, "-resize", "1920x1920>", "-quality", "85", bg_path], check=True, capture_output=True)
            tmp_zip = f"{work}/theme.zip"
            with zipfile.ZipFile(tmp_zip, "w", zipfile.ZIP_DEFLATED) as z:
                z.writestr("colors.tdesktop-theme", colors)
                z.write(bg_path, "background.jpg")
            shutil.move(tmp_zip, OUT)
    else:
        with open(OUT, "w") as f:
            f.write(colors)

    return 0


if __name__ == "__main__":
    sys.exit(main())
